{
  "$schema": "https://github.com/oxc-project/oxc/blob/main/npm/oxfmt/configuration_schema.json",
  "javascript": {
    "quote": "double",
    "jsxQuote": "double",
    "quoteProperties": "as-needed",
    "trailingCommas": "all",
    "semicolons": "always",
    "arrowParentheses": "always",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "singleAttributePerLine": false
  },
  "json": {
    "trailingCommas": "none"
  },
  "typescript": {
    "quote": "double",
    "trailingCommas": "all",
    "semicolons": "always"
  },
  "jsx": {
    "quote": "double"
  },
  "yaml": {},
  "markdown": {}
}
